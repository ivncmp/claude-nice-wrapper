{
  "name": "claude-nice-wrapper",
  "version": "0.1.0",
  "description": "CLI wrapper for claude -p with history, memory, chat, and templates",
  "type": "module",
  "author": "Iván Campillo <ivncmp@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/ivncmp/claude-nice-wrapper.git"
  },
  "homepage": "https://github.com/ivncmp/claude-nice-wrapper#readme",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "cw": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "check": "eslint . && prettier --check \"src/**/*.ts\" && tsup",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "cli",
    "wrapper",
    "ai"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.17",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "globals": "^17.5.0",
    "prettier": "^3.8.2",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.1"
  },
  "dependencies": {
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "yaml": "^2.7.0"
  }
}
